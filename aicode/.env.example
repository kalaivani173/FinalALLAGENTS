# Copy this file to .env and set your real key. Do not commit .env to git.
# OPENAI_API_KEY=sk-your-openai-api-key-here

OPENAI_API_KEY=

# Optional: path to javacoderepo for Deploy (Field Addition only). Default: sibling directory javacoderepo.
# JAVACODEREPO_ROOT=d:\UPI-Hackathon-2\javacoderepo
# Optional: Java codebase path for Api Addition patch generation. Default: JAVACODEREPO_ROOT/UPISim/src/main/java
# JAVA_CODEBASE_PATH=d:\UPI-Hackathon-2\javacoderepo\UPISim\src\main\java

# ---- Deploy ----
# Set to 1 to enable dry-run only (no files written, no Git). Use for validation.
# DEPLOY_DRY_RUN=0

# ---- Deploy Git integration ----
# Set to 1 to enable Git commit (and optionally push) after deploy.
# DEPLOY_GIT_ENABLED=0
# DEPLOY_PUSH_TO_GIT=1
# Commit only (no push). Useful for manual push or CI.
# DEPLOY_GIT_COMMIT_ONLY=0
# Branch to commit/push to. Empty = use current branch.
# DEPLOY_GIT_BRANCH=
# Remote name for push.
# DEPLOY_GIT_REMOTE=origin
# Commit message template. Placeholders: {changeId}, {timestamp}.
# DEPLOY_GIT_COMMIT_MESSAGE_TEMPLATE=Deploy field-addition: {changeId}
# Allow deploy when repo has other uncommitted changes (default: 0 = disallow).
# DEPLOY_GIT_ALLOW_DIRTY_REPO=0
# Timeouts in seconds for git add, commit, push.
# DEPLOY_GIT_ADD_TIMEOUT=30
# DEPLOY_GIT_COMMIT_TIMEOUT=30
# DEPLOY_GIT_PUSH_TIMEOUT=60
# Number of retries for git push on transient failure.
# DEPLOY_GIT_PUSH_RETRIES=2
