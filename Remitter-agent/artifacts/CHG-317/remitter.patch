+        txn.setCustRef(custRef);
+        txn.setType("Mandate");
+        txn.setNote("ReqMandate");
+        txn.setRefId(custRef);
+        txn.setRefUrl("www.payer.com");
+        txn.setTs(ZonedDateTime.now().format(DateTimeFormatter.ISO_OFFSET_DATE_TIME));
+        reqMandate.setTxn(txn);
+
+        return reqMandate;
+    }
